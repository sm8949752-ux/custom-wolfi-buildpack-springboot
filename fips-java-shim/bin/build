#!/bin/sh
set -e

layers_dir="$1"
java_layer="${layers_dir}/java-fips"

mkdir -p "$java_layer/env.build"
mkdir -p "$java_layer/env.launch"

echo "[types]" > "${java_layer}.toml"
echo "launch = true" >> "${java_layer}.toml"
echo "build = true" >> "${java_layer}.toml"

JDK_PATH="/opt/java"

# 3. تعيين JAVA_HOME
printf "%s" "$JDK_PATH" > "$java_layer/env.build/JAVA_HOME"
printf "%s" "$JDK_PATH" > "$java_layer/env.launch/JAVA_HOME"

KEYSTORE_PWD="changeit"

FIPS_OPTS="-Dorg.bouncycastle.fips.approved_only=true \
-Dorg.bouncycastle.jsse.client.assumeExtendedKeyUsage=false \
-Dorg.bouncycastle.jsse.trustManager.checkEKU=true \
-Djdk.tls.trustNameService=true \
-Dkeystore.type=BCFKS \
-Djavax.net.ssl.trustStore=$JDK_PATH/lib/security/cacerts \
-Djavax.net.ssl.trustStoreType=BCFKS \
-Djavax.net.ssl.trustStorePassword=$KEYSTORE_PWD \
-Xbootclasspath/a:$JDK_PATH/lib/bc-fips.jar:$JDK_PATH/lib/bcutil-fips.jar:$JDK_PATH/lib/bctls-fips.jar"

printf "%s" "$FIPS_OPTS" > "$java_layer/env.build/JAVA_TOOL_OPTIONS"
printf "%s" "$FIPS_OPTS" > "$java_layer/env.launch/JAVA_TOOL_OPTIONS"

echo "Success: FIPS parameters applied. Ready for Maven."